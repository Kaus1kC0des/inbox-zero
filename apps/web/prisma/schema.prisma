datasource db {
  provider = "mysql"
}

generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}


// QikOffice user table — maps to existing `user` table
model User {
  id        BigInt    @id @map("user_id")
  name      String    @default("")
  email     String    @unique
  avatar    String?
  createdAt DateTime  @default(now()) @map("created_dt")

  accounts      Account[]
  emailAccounts EmailAccount[]

  @@map("user")
}

// OAuth tokens for linked email accounts (Google/Microsoft)
model Account {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  userId                BigInt    @map("user_id")
  provider              String
  type                  String    @default("oidc")
  providerAccountId     String    @map("provider_account_id")
  refresh_token         String?   @db.Text
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  access_token          String?   @db.Text
  expires_at            DateTime? @default(now())
  disconnectedAt        DateTime? @map("disconnected_at")
  token_type            String?
  scope                 String?
  id_token              String?   @db.Text
  session_state         String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccount          EmailAccount?

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("iz_account")
}

// Per-email settings, links iz_account to an email address
model EmailAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name      String?
  image     String?
  signature String?  @db.Text
  timezone  String?

  lastSyncedHistoryId            String?   @map("last_synced_history_id")
  watchEmailsExpirationDate      DateTime? @map("watch_emails_expiration_date")
  watchEmailsSubscriptionId      String?   @map("watch_emails_subscription_id")

  userId    BigInt   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String   @unique @map("account_id")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("iz_email_account")
}
